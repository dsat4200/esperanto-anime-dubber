Dialogue: 0,0:00:26.12,0:00:27.04,main,,0000,0000,0000,,Onii-chan!
Dialogue: 0,0:00:28.77,0:00:30.92,main,,0000,0000,0000,,Venu, kiom longe vi restos en la lito?
Dialogue: 0,0:00:30.92,0:00:32.42,main,,0000,0000,0000,,Jam estas mateno.
Dialogue: 0,0:00:32.42,0:00:35.64,main,,0000,0000,0000,,Matenmanĝo malvarmiĝos se vi ne ellitiĝos.
Dialogue: 0,0:00:35.64,0:00:37.18,main,,0000,0000,0000,,Mi faris ĝin por vi kaj ĉio.
Dialogue: 0,0:00:40.03,0:00:42.64,main,,0000,0000,0000,,Demetu vian ĉemizon, mi metos ĝin en la lavon.
Dialogue: 0,0:00:48.61,0:00:50.55,main,,0000,0000,0000,,Vi estas falsaĵo.
Dialogue: 0,0:00:51.53,0:00:58.78,main,,0000,0000,0000,,Vidu, mia fratino neniam vekus min aŭ kuirus matenmanĝon aŭ lavus mian vestaĵon.
Dialogue: 0,0:00:58.78,0:01:05.16,main,,0000,0000,0000,,Fakte, ŝi tute malestimas min kaj traktas min kiel idioton, aŭ tute ignoras min!
Dialogue: 0,0:01:05.16,0:01:06.79,main,,0000,0000,0000,,Ŝi ne aŭskultas vorton, kiun mi diras!
Dialogue: 0,0:01:06.79,0:01:10.83,main,,0000,0000,0000,,Neniel ŝi venus en mian ĉambron tiel por veki min!
Dialogue: 0,0:01:10.83,0:01:11.80,main,,0000,0000,0000,,Onii-chan?
Dialogue: 0,0:01:11.80,0:01:14.34,main,,0000,0000,0000,,Esence, kion mi provas diri estas...
Dialogue: 0,0:01:14.34,0:01:16.71,main,,0000,0000,0000,,Ne estas maniero, ke mia fratino ne povas esti tiel bela—
Dialogue: 0,0:01:29.86,0:01:37.15,op-rom,,0000,0000,0000,,Kian vizaĝon mi faru, se mi ne traktas vin tiel afable?
Dialogue: 0,0:01:29.86,0:01:37.15,op-eng,,0000,0000,0000,,Ne estu tiel afabla al mi, mi simple ne scias kiel reagi
Dialogue: 0,0:01:37.15,0:01:47.26,op-rom,,0000,0000,0000,,Mi ne povas vidi vian profilon pro la amasigitaj vortoj
Dialogue: 0,0:01:37.15,0:01:47.26,op-eng,,0000,0000,0000,,Kun ĉiuj ĉi vortoj amasiĝantaj, mi eĉ ne povas vidi vian vizaĝon
Dialogue: 0,0:01:52.21,0:01:59.56,op-rom,,0000,0000,0000,,Kie ĝi estas?Mi ne povas trovi miajn perditajn ŝlosilojn, panjo.
Dialogue: 0,0:01:52.21,0:01:59.56,op-eng,,0000,0000,0000,,Kie ĝi estas?Mi perdis mian ŝlosilon, nun mi ne trovas ĝin
Dialogue: 0,0:01:59.56,0:02:06.23,op-rom,,0000,0000,0000,,Mi laciĝas daŭrigi miajn ĝemojn dum ni preterpasas.
Dialogue: 0,0:01:59.56,0:02:06.23,op-eng,,0000,0000,0000,,Suspiro, mi elĉerpiĝos, se mi daŭre agas tiel, kiam ajn ni maltrafos
Dialogue: 0,0:02:06.23,0:02:12.95,op-rom,,0000,0000,0000,,La distanco inter vi kaj mi estas iom pli proksima al la libro.
Dialogue: 0,0:02:06.23,0:02:12.95,op-eng,,0000,0000,0000,,Eble ni estas proksimaj?Mi simple ne povas eltrovi
Dialogue: 0,0:02:12.95,0:02:20.32,op-rom,,0000,0000,0000,,Mi ne povas bone kompreni ĝin, sed post iom da tempo
Dialogue: 0,0:02:12.95,0:02:20.32,op-eng,,0000,0000,0000,,Kiom malproksime mi estas, kvankam vi estas ĝuste tie
Dialogue: 0,0:02:20.32,0:02:27.17,op-rom,,0000,0000,0000,,Ne estu tiel afabla al mi, ni denove vundu unu la alian
Dialogue: 0,0:02:20.32,0:02:27.17,op-eng,,0000,0000,0000,,Ne estu tiel agrabla al mi, ĉu vi?Ni denove vundas unu la alian
Dialogue: 0,0:02:27.17,0:02:34.29,op-rom,,0000,0000,0000,,Eĉ kun ĉiuj mensogoj, kiujn mi amasigis, mi ne povas moviĝi
Dialogue: 0,0:02:27.17,0:02:34.29,op-eng,,0000,0000,0000,,Kun ĉiuj ĉi mensogoj amasiĝantaj, mi eĉ ne povas moviĝi
Dialogue: 0,0:02:34.29,0:02:41.60,op-rom,,0000,0000,0000,,Mi volas tuj enamiĝi, sed mi ne trovas la vortojn.
Dialogue: 0,0:02:34.29,0:02:41.60,op-eng,,0000,0000,0000,,Mi volas vidi vin nun, sed mi ne scias kion diri
Dialogue: 0,0:02:41.60,0:02:51.94,op-rom,,0000,0000,0000,,La lasta paĝo?Mi volas montri al vi rideton
Dialogue: 0,0:02:41.60,0:02:51.94,op-eng,,0000,0000,0000,,Ĉu ĉi tio estas la fino de nia rakonto?Mi volas, ke vi vidu mian rideton
Dialogue: 0,0:02:59.15,0:03:02.68,title,,0000,0000,0000,,{\alphaff\t(700,1443,0.8,\alpha00)}{\shad0\fs60\fnAngeleobardo\c&H4ED67F&\bord0.15\be1\frz3.325\pos(750,595.5)}Ne ekzistas maniero, ke mi povus ami mian fratinon
Dialogue: 0,0:03:05.97,0:03:07.91,main,,0000,0000,0000,,Bone, jen la via.
Dialogue: 0,0:03:09.12,0:03:10.41,main,,0000,0000,0000,,Kie estas Kirino?
Dialogue: 0,0:03:10.94,0:03:12.79,main,,0000,0000,0000,,Ŝi jam foriris.
Dialogue: 0,0:03:12.79,0:03:14.33,main,,0000,0000,0000,,Ŝi havas matenan ekzercon hodiaŭ.
Dialogue: 0,0:03:14.33,0:03:15.39,main,,0000,0000,0000,,mi vidas.
Dialogue: 0,0:03:15.39,0:03:17.64,main,,0000,0000,0000,,Ŝi denove rompis sian rekordon.
Dialogue: 0,0:03:17.64,0:03:20.83,main,,0000,0000,0000,,Ili diras, ke ŝi eble iros al granda turniro baldaŭ!
Dialogue: 0,0:03:20.83,0:03:21.85,main,,0000,0000,0000,,mi vidas.
Dialogue: 0,0:03:21.85,0:03:22.72,main,,0000,0000,0000,,Dankon pro la manĝaĵo.
Dialogue: 0,0:03:22.72,0:03:25.03,main,,0000,0000,0000,,"Mi vidas" estas ĉio, kion vi diras hodiaŭ!
Dialogue: 0,0:03:35.30,0:03:37.43,main,,0000,0000,0000,,Matene, Kyou-chan!
Dialogue: 0,0:03:41.23,0:03:43.70,main,,0000,0000,0000,,Kirino-chan havis matenan ekzercon?
Dialogue: 0,0:03:44.16,0:03:47.39,main,,0000,0000,0000,,Estas malfacile vivi en la ombro de superatinganta fratineto.
Dialogue: 0,0:03:47.39,0:03:50.35,main,,0000,0000,0000,,Ŝi ankaŭ estas inteligenta kaj bela.
Dialogue: 0,0:03:50.35,0:03:52.15,main,,0000,0000,0000,,Ĉiuj en la komerca kvartalo parolas pri ŝi.
Dialogue: 0,0:03:52.15,0:03:54.17,main,,0000,0000,0000,,Do mi estas hontigita urba?
Dialogue: 0,0:03:54.53,0:03:57.87,main,,0000,0000,0000,,Mi volas nur vivi mian vivon trankvile...
Dialogue: 0,0:03:57.87,0:03:59.85,main,,0000,0000,0000,,Normala estas plej bona por ni homoj.
Dialogue: 0,0:03:59.85,0:04:02.55,main,,0000,0000,0000,,Sekulara, ordinara, aŭ kiel la plimulto.
Dialogue: 0,0:04:03.17,0:04:05.80,main,,0000,0000,0000,,Laŭ tiu difino, vi estas perfekta.
Dialogue: 0,0:04:06.66,0:04:10.63,main,,0000,0000,0000,,Se estus konkurso de Miss Normal, vi facile akirus la unuan lokon.
Dialogue: 0,0:04:10.63,0:04:11.93,main,,0000,0000,0000,,La Normala Reĝino.
Dialogue: 0,0:04:11.93,0:04:15.40,main,,0000,0000,0000,,Ĉu vere?Kiel embarasa...
Dialogue: 0,0:04:16.28,0:04:18.94,main,,0000,0000,0000,,Ne, tio ja ne estis komplimento.
Dialogue: 0,0:04:18.94,0:04:20.31,main,,0000,0000,0000,,Prenu viajn sidlokojn.
Dialogue: 0,0:04:20.31,0:04:22.26,main,,0000,0000,0000,,Ni komencas hejmĉambron.
Dialogue: 0,0:04:22.94,0:04:25.37,main,,0000,0000,0000,,"Alportu al mi arbon de pluvneĝo, ĉu, Kenji?"
Dialogue: 0,0:04:25.37,0:04:30.30,main,,0000,0000,0000,,Ĉi tiu linio estas de la "Mateno de Fina Adiaŭo" de Miyazawa Kenji, kiu estis skribita por lia fratino.
Dialogue: 0,0:04:30.30,0:04:33.50,main,,0000,0000,0000,,Ĝi signifas "Bonvolu alporti al mi arbon de pluvo".
Dialogue: 0,0:04:33.88,0:04:40.01,main,,0000,0000,0000,,Kinejoj de lia vivo diras ke lia fratino estis grava influo en lia vivo.
Dialogue: 0,0:04:40.89,0:04:43.38,main,,0000,0000,0000,,...lia pli juna fratino.
Dialogue: 0,0:04:43.38,0:04:45.01,main,,0000,0000,0000,,Bone, nun en la japana.
Dialogue: 0,0:04:45.93,0:04:50.99,main,,0000,0000,0000,,"Anstataŭ Georgo veturis lia fratineto."
Dialogue: 0,0:04:52.47,0:04:59.56,main,,0000,0000,0000,,Kaj tiel Ono no Imoko estis tiu, kiu liveris la faman leteron de Princo Shoutoku "Filo de Ĉielo el la Lando de la Leviĝanta Suno".
Dialogue: 0,0:05:00.95,0:05:02.14,main,,0000,0000,0000,,Ĝis revido!
Dialogue: 0,0:05:04.38,0:05:05.66,main,,0000,0000,0000,,Kio diable estis kun hodiaŭ?
Dialogue: 0,0:05:05.66,0:05:07.66,main,,0000,0000,0000,,Iu internacia apreza tago de fratineto?
Dialogue: 0,0:05:08.20,0:05:09.35,main,,0000,0000,0000,,Kio?
Dialogue: 0,0:05:09.35,0:05:10.66,main,,0000,0000,0000,,Nenio.
Dialogue: 0,0:05:12.66,0:05:14.85,main,,0000,0000,0000,,Ĝis morgaŭ!
Dialogue: 0,0:05:14.85,0:05:15.90,main,,0000,0000,0000,,Jes.
Dialogue: 0,0:05:24.92,0:05:27.15,main,,0000,0000,0000,,Jes, ankaŭ mi iris tien!
Dialogue: 0,0:05:27.15,0:05:29.18,main,,0000,0000,0000,,Tiu loko estas freneza!
Dialogue: 0,0:05:29.18,0:05:30.79,main,,0000,0000,0000,,Sed ĉu vi ne pensas, ke la servo aĉas?
Dialogue: 0,0:05:30.79,0:05:33.06,main,,0000,0000,0000,,Ili ignoris min la unuan fojon.
Dialogue: 0,0:05:35.85,0:05:36.92,main,,0000,0000,0000,,Ankaŭ vi, Ayase?
Dialogue: 0,0:05:36.92,0:05:40.00,main,,0000,0000,0000,,Jes, tiu kun la grasaj kruroj!
Dialogue: 0,0:05:40.00,0:05:42.46,main,,0000,0000,0000,,Kio?Tio estas tiel stulta!
Dialogue: 0,0:05:45.59,0:05:47.45,main,,0000,0000,0000,,Neniel, la alia!
Dialogue: 0,0:05:47.45,0:05:49.66,main,,0000,0000,0000,,Vi scias, la loko pri kiu rakontis al ni Kanako!
Dialogue: 0,0:05:50.73,0:05:52.16,main,,0000,0000,0000,,Ho, kio estis denove...
Dialogue: 0,0:05:53.71,0:05:54.83,main,,0000,0000,0000,,Jes!
Dialogue: 0,0:05:55.47,0:05:56.56,main,,0000,0000,0000,,Jes.
Dialogue: 0,0:05:56.56,0:05:58.06,main,,0000,0000,0000,,Ĉu vi ne memoras?
Dialogue: 0,0:05:58.06,0:06:00.88,main,,0000,0000,0000,,Ni iris tien kune post la pafado!
Dialogue: 0,0:06:00.88,0:06:03.69,main,,0000,0000,0000,,Ĉu ne estis en majo?
Dialogue: 0,0:06:03.69,0:06:04.58,main,,0000,0000,0000,,Jes...
Dialogue: 0,0:06:05.47,0:06:06.05,main,,0000,0000,0000,,Jes.
Dialogue: 0,0:06:07.11,0:06:09.80,main,,0000,0000,0000,,Estas bone, mi kondukos vin tien.
Dialogue: 0,0:06:11.01,0:06:12.05,main,,0000,0000,0000,,Ho, ĉu estas hodiaŭ?
Dialogue: 0,0:06:37.28,0:06:38.49,main,,0000,0000,0000,,Pardonu.
Dialogue: 0,0:06:43.79,0:06:44.50,main,,0000,0000,0000,,Ne tuŝu ĝin!
Dialogue: 0,0:06:54.85,0:06:56.20,main,,0000,0000,0000,,Mi eliras.
Dialogue: 0,0:06:58.33,0:06:59.71,main,,0000,0000,0000,,Kio diable.
Dialogue: 0,0:07:09.52,0:07:10.38,main,,0000,0000,0000,,Kio?
Dialogue: 0,0:07:14.32,0:07:16.72,main,,0000,0000,0000,,Kial ŝia hararo estas rozkolora?
Dialogue: 0,0:07:17.56,0:07:19.06,main,,0000,0000,0000,,Mi estas hejme!
Dialogue: 0,0:07:19.06,0:07:20.56,main,,0000,0000,0000,,Kio malbonas, Kyousuke?
Dialogue: 0,0:07:20.56,0:07:22.44,main,,0000,0000,0000,,Kio estas kun la feta pozicio?
Dialogue: 0,0:07:22.44,0:07:23.60,main,,0000,0000,0000,,Ne atentu min.
Dialogue: 0,0:07:23.60,0:07:25.62,main,,0000,0000,0000,,Mi nur sentis ŝanĝon de ritmo.
Dialogue: 0,0:07:25.62,0:07:26.32,main,,0000,0000,0000,,Ho?
Dialogue: 0,0:07:37.53,0:07:40.40,main,,0000,0000,0000,,Mi preskaŭ mortis kiel membro de la socio tie...
Dialogue: 0,0:07:40.40,0:07:42.58,main,,0000,0000,0000,,Kies do ĉi tio estas?
Dialogue: 0,0:07:45.28,0:07:46.36,main,,0000,0000,0000,,Ĉu de paĉjo?
Dialogue: 0,0:07:49.94,0:07:50.92,main,,0000,0000,0000,,Ĉu de panjo?
Dialogue: 0,0:07:54.97,0:07:56.10,main,,0000,0000,0000,,Kirino?
Dialogue: 0,0:07:57.37,0:07:58.99,main,,0000,0000,0000,,Neniu el ili ŝajnas kongrui...
Dialogue: 0,0:08:00.72,0:08:03.31,note,,0000,0000,0000,,Amu kun Fratineto!— Limigita Unua Eldono
Dialogue: 0,0:08:05.60,0:08:07.25,main,,0000,0000,0000,,Stelpolva Sorĉistino...
Dialogue: 0,0:08:07.25,0:08:08.31,main,,0000,0000,0000,,Fratineto...
Dialogue: 0,0:08:08.31,0:08:09.10,main,,0000,0000,0000,,Merle...
Dialogue: 0,0:08:09.10,0:08:10.15,main,,0000,0000,0000,,Faru amon...
Dialogue: 0,0:08:10.15,0:08:11.49,main,,0000,0000,0000,,Limigita Eldono...
Dialogue: 0,0:08:11.49,0:08:12.55,main,,0000,0000,0000,,R-18...
Dialogue: 0,0:08:13.61,0:08:15.34,main,,0000,0000,0000,,Mi faras kelkajn frenezajn erarojn!
Dialogue: 0,0:08:15.34,0:08:21.49,main,,0000,0000,0000,,Mi kaptis la plej proksiman kazon dum mi formetis ĉi tiun KD kaj ŝanĝis la enhavon!
Dialogue: 0,0:08:23.35,0:08:24.74,main,,0000,0000,0000,,Kio diable?!
Dialogue: 0,0:08:24.74,0:08:26.37,main,,0000,0000,0000,,Fari amon?Kun Fratineto?
Dialogue: 0,0:08:26.37,0:08:27.63,main,,0000,0000,0000,,Kiel diable!!
Dialogue: 0,0:08:27.63,0:08:30.44,main,,0000,0000,0000,,Kion diable vi volas, ke mi faru?!
Dialogue: 0,0:08:30.44,0:08:31.82,main,,0000,0000,0000,,Kaj R-18?!
Dialogue: 0,0:08:32.22,0:08:33.95,main,,0000,0000,0000,,Ĉi tio estas eroge, diable!!
Dialogue: 0,0:08:38.74,0:08:42.56,main,,0000,0000,0000,,Kyousuke!Ĉu la malpuraj revuoj, kiujn vi kaŝas sub via lito, ne estis sufiĉe bonaj por vi?
Dialogue: 0,0:08:42.91,0:08:44.81,main,,0000,0000,0000,,Vi ŝercas min.Tio estas serioze malpura.
Dialogue: 0,0:08:46.41,0:08:47.08,main,,0000,0000,0000,,Morti.
Dialogue: 0,0:08:47.82,0:08:49.15,main,,0000,0000,0000,,Ĉi tio estas grave malbona...
Dialogue: 0,0:08:49.15,0:08:51.84,main,,0000,0000,0000,,Se mi estas kaptita kun ĉi tio...
Dialogue: 0,0:08:51.84,0:08:53.12,main,,0000,0000,0000,,Kyosuke!
Dialogue: 0,0:08:53.12,0:08:54.76,main,,0000,0000,0000,,Ĉu vi studas—
Dialogue: 0,0:08:55.55,0:08:56.64,main,,0000,0000,0000,,—ĉu?
Dialogue: 0,0:08:57.07,0:08:58.81,main,,0000,0000,0000,,Ĉu mi venis en malbona tempo?
Dialogue: 0,0:08:58.81,0:08:59.87,main,,0000,0000,0000,,Ne atentu min!
Dialogue: 0,0:08:59.87,0:09:01.35,main,,0000,0000,0000,,Mi nur trejnas mian voĉkeston!
Dialogue: 0,0:09:01.71,0:09:04.37,main,,0000,0000,0000,,Kaj frapu venontfoje!!
Dialogue: 0,0:09:04.97,0:09:06.02,main,,0000,0000,0000,,Pardonu!
Dialogue: 0,0:09:07.70,0:09:11.56,main,,0000,0000,0000,,Mi certe ekscios, kiu estas la vera kulpulo!
Dialogue: 0,0:09:22.72,0:09:24.12,main,,0000,0000,0000,,Kion vi faras?
Dialogue: 0,0:09:24.72,0:09:25.60,main,,0000,0000,0000,,Ĉu?
Dialogue: 0,0:09:25.60,0:09:26.71,main,,0000,0000,0000,,Neniu el via afero.
Dialogue: 0,0:09:29.31,0:09:30.61,main,,0000,0000,0000,,Ĉu tiel?
Dialogue: 0,0:09:32.00,0:09:35.65,note,,0000,0000,0000,,En ĉi tiu momento, la suspektato malhelpas justecon konservante silenton.
Dialogue: 0,0:09:35.18,0:09:38.46,main,,0000,0000,0000,,Mi iros al la oportuna vendejo poste.Ĉu vi bezonas ion?
Dialogue: 0,0:09:38.46,0:09:40.43,main,,0000,0000,0000,,Prenu al mi glaciaĵon.
Dialogue: 0,0:09:39.16,0:09:40.89,note,,0000,0000,0000,,La kulpulo estas inter ni!
Dialogue: 0,0:09:42.82,0:09:47.65,main,,0000,0000,0000,,Ho jes, amiko mia tre eniris ĉi tiun animeon celitan al knabinoj lastatempe.
Dialogue: 0,0:09:49.25,0:09:51.40,main,,0000,0000,0000,,"Stelpolvo" aŭ io.
Dialogue: 0,0:09:51.71,0:09:53.20,main,,0000,0000,0000,,Pri kio vi parolas?
Dialogue: 0,0:09:53.20,0:09:56.99,main,,0000,0000,0000,,Nu, ĝi sonis interese, do mi pensis, ke mi povus provi ĝin.
Dialogue: 0,0:09:56.99,0:09:59.47,main,,0000,0000,0000,,Ĉu ne tion rigardas tiuj "otaku"-oj?
Dialogue: 0,0:09:59.47,0:10:01.16,main,,0000,0000,0000,,Ili foje parolas pri ili en televido.
Dialogue: 0,0:10:01.16,0:10:03.70,main,,0000,0000,0000,,Ne fariĝu kiel ili.
Dialogue: 0,0:10:03.70,0:10:05.03,main,,0000,0000,0000,,Ĉu ĉu, paĉjo?
Dialogue: 0,0:10:05.03,0:10:06.26,main,,0000,0000,0000,,Ĝuste.
Dialogue: 0,0:10:06.26,0:10:08.92,main,,0000,0000,0000,,Ne malpurigu vian menson per tiu malpuraĵo.
Dialogue: 0,0:10:09.38,0:10:10.99,main,,0000,0000,0000,,Bone.
Dialogue: 0,0:10:10.99,0:10:13.70,main,,0000,0000,0000,,Mi supozas, ke tiu reago forigas ilin.
Dialogue: 0,0:10:13.70,0:10:14.92,main,,0000,0000,0000,,Kio signifas...
Dialogue: 0,0:10:22.69,0:10:24.06,main,,0000,0000,0000,,Kio estas malbona, Kirino?
Dialogue: 0,0:10:25.17,0:10:26.44,main,,0000,0000,0000,,Dankon pro la manĝo!
Dialogue: 0,0:10:39.79,0:10:40.84,main,,0000,0000,0000,,Neniel...
Dialogue: 0,0:10:43.72,0:10:45.28,main,,0000,0000,0000,,Bone do...
Dialogue: 0,0:10:45.28,0:10:47.12,main,,0000,0000,0000,,Mi supozas, ke mi iros al la facilbutiko...
Dialogue: 0,0:10:50.22,0:10:51.12,main,,0000,0000,0000,,Neniel...
Dialogue: 0,0:10:55.52,0:10:56.57,main,,0000,0000,0000,,Neniel!
Dialogue: 0,0:11:08.14,0:11:08.95,main,,0000,0000,0000,,Hej.
Dialogue: 0,0:11:09.80,0:11:11.62,main,,0000,0000,0000,,Kion vi faras?
Dialogue: 0,0:11:11.62,0:11:13.12,main,,0000,0000,0000,,Kiu zorgas pri tio, kion mi faras?
Dialogue: 0,0:11:13.12,0:11:15.89,main,,0000,0000,0000,,Mi zorgas!!Jen mia ĉambro!
Dialogue: 0,0:11:21.70,0:11:22.52,main,,0000,0000,0000,,Movu.
Dialogue: 0,0:11:22.52,0:11:24.42,main,,0000,0000,0000,,Respondu mian demandon.
Dialogue: 0,0:11:24.42,0:11:24.95,main,,0000,0000,0000,,Movu!
Dialogue: 0,0:11:27.49,0:11:28.91,main,,0000,0000,0000,,Jen kion vi serĉas, ĉu ne?
Dialogue: 0,0:11:29.79,0:11:31.47,main,,0000,0000,0000,,Do ĝi estas via!
Dialogue: 0,0:11:31.47,0:11:33.30,main,,0000,0000,0000,,Pri kio vi parolas?
Dialogue: 0,0:11:33.30,0:11:35.69,main,,0000,0000,0000,,Neniel mi spektus animeon tia!
Dialogue: 0,0:11:35.69,0:11:38.60,main,,0000,0000,0000,,Viaj agoj ne kongruas kun viaj vortoj!
Dialogue: 0,0:11:42.41,0:11:46.70,main,,0000,0000,0000,,Se vi ne serĉis ĉi tion, kion vi faris en mia ĉambro?
Dialogue: 0,0:11:46.70,0:11:48.06,main,,0000,0000,0000,,mi estis...
Dialogue: 0,0:11:49.25,0:11:50.93,main,,0000,0000,0000,,mi estis...
Dialogue: 0,0:11:52.21,0:11:53.69,main,,0000,0000,0000,,mi estis...
Dialogue: 0,0:11:57.95,0:11:59.95,main,,0000,0000,0000,,Jen, prenu ĝin.
Dialogue: 0,0:11:59.95,0:12:01.16,main,,0000,0000,0000,,Mi diris, ke ĝi ne estas—
Dialogue: 0,0:12:01.16,0:12:03.65,main,,0000,0000,0000,,Tiam forĵetu ĝin por mi.
Dialogue: 0,0:12:03.65,0:12:04.03,main,,0000,0000,0000,,Ĉu?
Dialogue: 0,0:12:04.51,0:12:07.43,main,,0000,0000,0000,,Pardonu, mi supozas, ke mi miskomprenis.
Dialogue: 0,0:12:07.43,0:12:08.83,main,,0000,0000,0000,,Ĝi ne estas via tiam.
Dialogue: 0,0:12:09.51,0:12:15.60,main,,0000,0000,0000,,Mi tamen ne volas porti ĝin, do forĵetu ĝin por mi, bonvolu.
Dialogue: 0,0:12:17.33,0:12:19.98,main,,0000,0000,0000,,F-Bone...
Dialogue: 0,0:12:23.50,0:12:24.89,main,,0000,0000,0000,,Ĉu vi pensas, ke ĝi estas stranga?
Dialogue: 0,0:12:25.93,0:12:31.01,main,,0000,0000,0000,,Mi diris, mi-se ĉi tio estus efektive mia,
Dialogue: 0,0:12:31.01,0:12:32.85,main,,0000,0000,0000,,ĉu vi pensus, ke tio estas stranga?
Dialogue: 0,0:12:35.31,0:12:37.36,main,,0000,0000,0000,,Kial mi pensus, ke tio estas stranga?
Dialogue: 0,0:12:39.89,0:12:40.86,main,,0000,0000,0000,,Ĉu vere?
Dialogue: 0,0:12:41.79,0:12:42.81,main,,0000,0000,0000,,Jes.
Dialogue: 0,0:12:42.81,0:12:45.32,main,,0000,0000,0000,,Ne gravas kiajn ŝatokupojn vi havas.
Dialogue: 0,0:12:45.32,0:12:47.12,main,,0000,0000,0000,,Mi ne mokus vin.
Dialogue: 0,0:12:48.53,0:12:49.64,main,,0000,0000,0000,,mi vidas.
Dialogue: 0,0:12:54.94,0:12:56.25,main,,0000,0000,0000,,Kio estas kun ŝi?
Dialogue: 0,0:13:04.84,0:13:07.63,main,,0000,0000,0000,,Ho aĉa, mi forgesis pri la glaciaĵo...
Dialogue: 0,0:13:13.00,0:13:14.31,main,,0000,0000,0000,,Kio vi estas—
Dialogue: 0,0:13:14.31,0:13:15.54,main,,0000,0000,0000,,Estu silenta.
Dialogue: 0,0:13:24.09,0:13:26.12,main,,0000,0000,0000,,Kion vi faras?
Dialogue: 0,0:13:29.55,0:13:31.41,main,,0000,0000,0000,,Mi-mi bezonas paroli kun vi.
Dialogue: 0,0:13:31.41,0:13:32.91,main,,0000,0000,0000,,Venu al mia ĉambro.
Dialogue: 0,0:13:33.53,0:13:35.36,main,,0000,0000,0000,,Ĉu tio povas atendi ĝis morgaŭ?
Dialogue: 0,0:13:35.36,0:13:36.38,main,,0000,0000,0000,,Ne.
Dialogue: 0,0:13:46.52,0:13:48.23,main,,0000,0000,0000,,Ne rigardu ĉion.
Dialogue: 0,0:13:48.23,0:13:49.53,main,,0000,0000,0000,,Mi ne rigardas!
Dialogue: 0,0:13:49.53,0:13:51.93,main,,0000,0000,0000,,Do, pri kio vi volis paroli?
Dialogue: 0,0:13:58.30,0:14:00.06,main,,0000,0000,0000,,Rapidu aŭ mi foriros de ĉi tie.
Dialogue: 0,0:14:01.18,0:14:02.82,main,,0000,0000,0000,,Vi diris pli frue...
Dialogue: 0,0:14:03.63,0:14:08.32,main,,0000,0000,0000,,Eĉ se mi havus tiajn aferojn, vi ne mokus min.
Dialogue: 0,0:14:08.57,0:14:10.17,main,,0000,0000,0000,,Ĉu?Jes...
Dialogue: 0,0:14:10.17,0:14:11.87,main,,0000,0000,0000,,Ŝatas, ĉu vere vere?
Dialogue: 0,0:14:11.87,0:14:13.20,main,,0000,0000,0000,,Neniuj demandoj?
Dialogue: 0,0:14:13.20,0:14:15.63,main,,0000,0000,0000,,Unufoje sufiĉas.Mi ne faros.
Dialogue: 0,0:14:15.63,0:14:17.47,main,,0000,0000,0000,,Se vi mensogas, mi mortigos vin.
Dialogue: 0,0:14:17.47,0:14:18.68,main,,0000,0000,0000,,Ĉu ŝi mortigos min?
Dialogue: 0,0:14:22.67,0:14:23.10,main,,0000,0000,0000,,Uh—
Dialogue: 0,0:14:23.10,0:14:23.92,main,,0000,0000,0000,,-konscio.
Dialogue: 0,0:14:23.92,0:14:25.92,main,,0000,0000,0000,,Kio?Mi ne aŭdis tion.
Dialogue: 0,0:14:27.47,0:14:29.18,main,,0000,0000,0000,,Mi volas iom da vivkonsilado!
Dialogue: 0,0:14:29.45,0:14:30.68,main,,0000,0000,0000,,Viva konsilado?
Dialogue: 0,0:14:31.20,0:14:32.47,main,,0000,0000,0000,,Vi?
Dialogue: 0,0:14:32.47,0:14:33.41,main,,0000,0000,0000,,De mi?
Dialogue: 0,0:14:37.89,0:14:39.35,main,,0000,0000,0000,,Ĉu vi havas ŝrankon?!
Dialogue: 0,0:14:39.35,0:14:41.43,main,,0000,0000,0000,,Ĉi tiu ĉambro estis origine japanstila.
Dialogue: 0,0:14:41.43,0:14:43.65,main,,0000,0000,0000,,Ĝi verŝajne restas de la restrukturado.
Dialogue: 0,0:14:44.19,0:14:46.86,main,,0000,0000,0000,,Do mi transformis ĝin en ĉi tion.
Dialogue: 0,0:14:53.03,0:14:54.93,main,,0000,0000,0000,,Y-Vi... th-ĉi—
Dialogue: 0,0:15:02.74,0:15:04.10,main,,0000,0000,0000,,K-Kio ĉi tio estas?!
Dialogue: 0,0:15:04.10,0:15:05.83,main,,0000,0000,0000,,Ho, tio estas la komputila versio.
Dialogue: 0,0:15:05.83,0:15:10.55,main,,0000,0000,0000,,Ĝi origine aperis sur PS2, sed ĝi fariĝis tute malsama serio post la haveno.
Dialogue: 0,0:15:10.92,0:15:15.05,main,,0000,0000,0000,,Ĝi estas ĉefverko, sed ĝi estas iom malfacila, do mi ne rekomendus ĝin al amatoro.
Dialogue: 0,0:15:15.05,0:15:16.72,main,,0000,0000,0000,,Mi ne demandis pri tio!
Dialogue: 0,0:15:15.05,0:15:17.75,overlap,,0000,0000,0000,,Cetere, ankaŭ mi havas ĉion antaŭ ĝi.{interkovro}
Dialogue: 0,0:15:16.72,0:15:18.23,main,,0000,0000,0000,,Kaj kio estas tio pri amatoroj?
Dialogue: 0,0:15:18.23,0:15:20.81,main,,0000,0000,0000,,Ĉu vi estas profesiulo?Profesiulo?!
Dialogue: 0,0:15:21.97,0:15:23.86,main,,0000,0000,0000,,Jen ni iras...
Dialogue: 0,0:15:23.86,0:15:25.67,main,,0000,0000,0000,,Ĉi tio estas serio 3, Super Sister-in-Law.
Dialogue: 0,0:15:25.67,0:15:27.40,main,,0000,0000,0000,,Serio 2, Ludante kun pli junaj fratinoj.
Dialogue: 0,0:15:27.40,0:15:28.76,main,,0000,0000,0000,,Serio 9, Tengen Toppa 12 Fratinoj.
Dialogue: 0,0:15:28.76,0:15:29.94,main,,0000,0000,0000,,Serio S 16, Final Weapon Sister.
Dialogue: 0,0:15:30.71,0:15:33.09,main,,0000,0000,0000,,Ĉu ĉi tiuj estas ĉiuj komputilaj ludoj?
Dialogue: 0,0:15:33.09,0:15:34.14,main,,0000,0000,0000,,Ĝuste.
Dialogue: 0,0:15:34.14,0:15:36.48,main,,0000,0000,0000,,Kial la skatoloj estas tiel grandaj?
Dialogue: 0,0:15:36.48,0:15:37.91,main,,0000,0000,0000,,Ankaŭ estas malgrandaj.
Dialogue: 0,0:15:37.91,0:15:44.87,main,,0000,0000,0000,,Mia Pli Juna Fratino Estas Mai Waifu, Bonvenon al Pli Juna Fratino Lando, Fratino Kolektanto: Imoking ~Pardonu ĝeni Vin Ĉiun Fratinon~.
Dialogue: 0,0:15:44.87,0:15:48.27,main,,0000,0000,0000,,Sed ĉi tiuj estas la ĉefaj.
Dialogue: 0,0:15:48.27,0:15:50.74,main,,0000,0000,0000,,Ili estas tute malsama sperto sur la ekrano.
Dialogue: 0,0:15:50.74,0:15:54.68,main,,0000,0000,0000,,Ili kaptas vian atenton eĉ se ĝi estas nur per poŝta mendo.
Dialogue: 0,0:15:54.68,0:15:57.22,main,,0000,0000,0000,,Eroge estas vetkuro kontraŭ la liberigo.
Dialogue: 0,0:15:55.40,0:15:57.22,overlap,,0000,0000,0000,,Pardonu, mi tute ne scias, pri kio vi parolas.
Dialogue: 0,0:15:57.59,0:15:58.77,main,,0000,0000,0000,,Kio estas ĉi tio?
Dialogue: 0,0:15:59.27,0:16:01.95,main,,0000,0000,0000,,Specialeldona animea DVD-skatolo.
Dialogue: 0,0:16:01.95,0:16:02.98,main,,0000,0000,0000,,Speciala eldono?
Dialogue: 0,0:16:03.40,0:16:09.13,main,,0000,0000,0000,,Re-redaktita kompleta versio de la televidelsendo kaj neelsenditaj epizodoj sur kromdiskoj kaj aĵoj!
Dialogue: 0,0:16:09.13,0:16:13.40,main,,0000,0000,0000,,Kaj specialaj libretoj kaj minidramoj kaj limigitaj eldonaj figuroj!
Dialogue: 0,0:16:13.77,0:16:14.74,main,,0000,0000,0000,,Mirinda, ĉu ne?
Dialogue: 0,0:16:15.22,0:16:18.38,main,,0000,0000,0000,,Tio... Stelpolvo Meruru kia ajn?
Dialogue: 0,0:16:18.38,0:16:20.20,main,,0000,0000,0000,,Stelpolva Sorĉistino Meruru!
Dialogue: 0,0:16:20.20,0:16:21.75,main,,0000,0000,0000,,Estas insulte, se vi ne bone komprenas!
Dialogue: 0,0:16:21.75,0:16:22.50,main,,0000,0000,0000,,Al kiu?
Dialogue: 0,0:16:22.50,0:16:28.36,main,,0000,0000,0000,,Ĉi tiu estas la elsenda versio, ĉi tiu estas la populara skatolo, R1-versio, R1-populara skatolo kaj Blu-Ray.
Dialogue: 0,0:16:28.36,0:16:31.03,main,,0000,0000,0000,,Kial vi aĉetis tiom da kopioj de la sama afero?!
Dialogue: 0,0:16:31.03,0:16:31.86,main,,0000,0000,0000,,Kiel propono!
Dialogue: 0,0:16:32.20,0:16:34.52,main,,0000,0000,0000,,Mi serioze komprenas nenion, kion vi diras.
Dialogue: 0,0:16:34.52,0:16:35.86,main,,0000,0000,0000,,Bone, trankviliĝu.
Dialogue: 0,0:16:35.86,0:16:37.37,main,,0000,0000,0000,,Provu kompreni ĉi tiun situacion.
Dialogue: 0,0:16:37.84,0:16:39.32,main,,0000,0000,0000,,Ĉi tio estas la ĉambro de mia fratino.
Dialogue: 0,0:16:38.62,0:16:41.10,overlap,,0000,0000,0000,,Mi estas tiom fiera pri mia kolekto! {interkovro} {io tia eble? Ne~mi faris ĝin perfekte~}
Dialogue: 0,0:16:39.32,0:16:40.90,main,,0000,0000,0000,,Mia fratino estas antaŭ mi,
Dialogue: 0,0:16:40.90,0:16:45.00,main,,0000,0000,0000,,kune kun monto de eroge kaj animeaj DVDoj.
Dialogue: 0,0:16:45.62,0:16:48.00,main,,0000,0000,0000,,Ĉu ĉi tiuj aferoj ne estas multekostaj?
Dialogue: 0,0:16:48.00,0:16:49.48,main,,0000,0000,0000,,Ia, mi supozas.
Dialogue: 0,0:16:49.48,0:16:53.62,main,,0000,0000,0000,,Ĉi tio estis ¥41,970, kaj tio estis ¥55,000.
Dialogue: 0,0:16:53.62,0:16:54.52,main,,0000,0000,0000,,Tio estas hele multekosta!
Dialogue: 0,0:16:54.52,0:16:55.43,main,,0000,0000,0000,,Vi estas mezlernejano!
Dialogue: 0,0:16:55.71,0:16:57.82,main,,0000,0000,0000,,De kie vi akiris tian monon?!
Dialogue: 0,0:16:57.82,0:16:59.24,main,,0000,0000,0000,,Moĝecoj, evidente.
Dialogue: 0,0:16:59.73,0:17:00.51,main,,0000,0000,0000,,Kio?
Dialogue: 0,0:17:02.85,0:17:05.44,main,,0000,0000,0000,,Ĉu vi estas modelo?
Dialogue: 0,0:17:05.44,0:17:06.31,main,,0000,0000,0000,,Jes.
Dialogue: 0,0:17:06.31,0:17:07.89,main,,0000,0000,0000,,Mi ne havis ideon...
Dialogue: 0,0:17:07.89,0:17:09.74,main,,0000,0000,0000,,Ĉu ĉi tio ne estas grava revuo?
Dialogue: 0,0:17:09.74,0:17:11.90,main,,0000,0000,0000,,Ĉu vi ŝatas, mirinda aŭ io?
Dialogue: 0,0:17:11.90,0:17:13.71,main,,0000,0000,0000,,Ne estas granda afero.
Dialogue: 0,0:17:13.71,0:17:14.67,main,,0000,0000,0000,,Vere.
Dialogue: 0,0:17:19.02,0:17:20.40,main,,0000,0000,0000,,Kaj do?
Dialogue: 0,0:17:20.87,0:17:22.61,main,,0000,0000,0000,,Kion vi volas diri, "tiel"?
Dialogue: 0,0:17:23.31,0:17:24.52,main,,0000,0000,0000,,Kion vi pensas?
Dialogue: 0,0:17:25.00,0:17:26.78,main,,0000,0000,0000,,Pri mia ŝatokupo.
Dialogue: 0,0:17:28.22,0:17:29.19,main,,0000,0000,0000,,Surprize.
Dialogue: 0,0:17:29.19,0:17:30.43,main,,0000,0000,0000,,Ĉu io alia?
Dialogue: 0,0:17:30.43,0:17:32.03,main,,0000,0000,0000,,Kion alian mi povas diri?
Dialogue: 0,0:17:34.42,0:17:38.64,main,,0000,0000,0000,,Ĉu estas strange por mi havi tiajn aferojn?
Dialogue: 0,0:17:38.64,0:17:39.81,main,,0000,0000,0000,,Ne, mi volas diri,
Dialogue: 0,0:17:39.81,0:17:44.65,main,,0000,0000,0000,,ĝi estas neatendita, sed vi aĉetas ĝin per via propra mono.
Dialogue: 0,0:17:44.65,0:17:46.64,main,,0000,0000,0000,,Kion vi aĉetas, estas via elekto.
Dialogue: 0,0:17:46.64,0:17:47.65,main,,0000,0000,0000,,Ĉu vi pensas tiel?
Dialogue: 0,0:17:47.65,0:17:48.29,main,,0000,0000,0000,,Ĉu vere?
Dialogue: 0,0:17:49.21,0:17:50.10,main,,0000,0000,0000,,Jes.
Dialogue: 0,0:17:50.10,0:17:52.65,main,,0000,0000,0000,,Vi ne devas zorgi pri tio, kion homoj pensas.
Dialogue: 0,0:17:52.65,0:17:54.54,main,,0000,0000,0000,,Mi nur miras.
Dialogue: 0,0:17:54.54,0:17:55.84,main,,0000,0000,0000,,Mi ne mokas vin nek ion ajn.
Dialogue: 0,0:17:56.59,0:17:58.95,main,,0000,0000,0000,,mi vidas.Vi pravas.
Dialogue: 0,0:18:00.26,0:18:01.81,main,,0000,0000,0000,,Vi foje diras bonajn aferojn!
Dialogue: 0,0:18:02.48,0:18:04.17,main,,0000,0000,0000,,Pensu pri ĝi...
Dialogue: 0,0:18:04.17,0:18:07.45,main,,0000,0000,0000,,Kial ĉiuj ĉi tiuj eroge estas la fratineto amo?
Dialogue: 0,0:18:08.31,0:18:09.73,main,,0000,0000,0000,,Kial vi pensas?
Dialogue: 0,0:18:09.73,0:18:10.80,main,,0000,0000,0000,,Neniu indico...
Dialogue: 0,0:18:12.41,0:18:13.72,main,,0000,0000,0000,,Kial vi retiriĝas?
Dialogue: 0,0:18:13.72,0:18:15.33,main,,0000,0000,0000,,Nu, vi...
Dialogue: 0,0:18:24.37,0:18:28.71,main,,0000,0000,0000,,Kiam vi rigardas ĉi tiun pakaĵon, ĉu vi ne pensas, ke ĝi povus esti bona?
Dialogue: 0,0:18:30.44,0:18:32.09,main,,0000,0000,0000,,Kion vi volas diri?
Dialogue: 0,0:18:33.59,0:18:37.72,main,,0000,0000,0000,,Rigardu ĝin!Ĉu ĝi ne estas vere bela?!
Dialogue: 0,0:18:39.63,0:18:43.36,main,,0000,0000,0000,,Alivorte, vi havas ĉiujn tiujn ludojn...
Dialogue: 0,0:18:44.21,0:18:46.29,main,,0000,0000,0000,,...ĉar vi ŝatas fratinetojn?
Dialogue: 0,0:18:46.29,0:18:46.73,main,,0000,0000,0000,,Jes!
Dialogue: 0,0:18:47.17,0:18:49.45,main,,0000,0000,0000,,Fratinetoj estas tiel belaj!
Dialogue: 0,0:18:49.45,0:18:55.77,main,,0000,0000,0000,,Kiel en ĉi tiuj galge, ili nomas vin "Onii-chan" aŭ "Aniki" aŭ "Nii-nii" aŭ "Nii-chama"!
Dialogue: 0,0:18:55.77,0:18:58.87,main,,0000,0000,0000,,Ili ĉiuj amas min kaj havas siajn proprajn nomojn por mi!
Dialogue: 0,0:18:58.87,0:19:02.74,main,,0000,0000,0000,,Ĝi nur frenezigas min!
Dialogue: 0,0:19:03.11,0:19:06.17,main,,0000,0000,0000,,Mi-mi vidas.Tio estas bela...
Dialogue: 0,0:19:06.17,0:19:08.96,main,,0000,0000,0000,,Nu, mi neniam estis nomita io tia,
Dialogue: 0,0:19:08.96,0:19:11.88,main,,0000,0000,0000,,kaj prefere ol freneziĝi, mi iritiĝus...
Dialogue: 0,0:19:11.88,0:19:14.90,main,,0000,0000,0000,,En ĉi tiu, mi amas ĉi tiun knabinon!
Dialogue: 0,0:19:14.90,0:19:18.60,main,,0000,0000,0000,,Pli junaj fratinoj devas havi nigrajn harojn kaj duvostojn!
Dialogue: 0,0:19:18.60,0:19:25.43,main,,0000,0000,0000,,Ili aspektas tiel puraj, vi volas nur protekti ilin aŭ teni ilin firme!{interkovro}
Dialogue: 0,0:19:18.60,0:19:20.04,overlap,,0000,0000,0000,,Via hararo estas bruna.
Dialogue: 0,0:19:22.99,0:19:25.43,overlap,,0000,0000,0000,,Vi mem atentigas viajn proprajn problemojn!
Dialogue: 0,0:19:25.43,0:19:27.46,main,,0000,0000,0000,,Ili estas tiel belaj!
Dialogue: 0,0:19:26.17,0:19:27.46,overlap,,0000,0000,0000,,Ŝi estas senespera.
Dialogue: 0,0:19:27.46,0:19:28.93,main,,0000,0000,0000,,Sed kial?
Dialogue: 0,0:19:30.10,0:19:32.98,main,,0000,0000,0000,,Kutime estas uloj kiuj aĉetas tiajn aferojn.
Dialogue: 0,0:19:32.98,0:19:34.32,main,,0000,0000,0000,,Kial estus—
Dialogue: 0,0:19:34.32,0:19:36.59,main,,0000,0000,0000,,Kial vi ŝatas ilin?
Dialogue: 0,0:19:37.12,0:19:38.18,main,,0000,0000,0000,,Mi ne scias.
Dialogue: 0,0:19:38.18,0:19:39.33,main,,0000,0000,0000,,Ĉu vi ne scias?
Dialogue: 0,0:19:39.60,0:19:41.43,main,,0000,0000,0000,,Mi vere ne scias kial!
Dialogue: 0,0:19:41.89,0:19:43.26,main,,0000,0000,0000,,Mi ne povas helpi ĝin.
Dialogue: 0,0:19:43.83,0:19:46.16,main,,0000,0000,0000,,Mi enamiĝis al ili antaŭ ol mi sciis tion.
Dialogue: 0,0:19:47.79,0:19:52.13,main,,0000,0000,0000,,Eĉ mi scias, ke ĉi tio ne estas ŝatokupo kiun normalaj knabinoj havas.
Dialogue: 0,0:19:52.59,0:19:54.68,main,,0000,0000,0000,,Tial mi kaŝis ĝin dum ĉi tiu tempo!
Dialogue: 0,0:19:55.39,0:19:57.47,main,,0000,0000,0000,,Sed mi vere amas ilin.
Dialogue: 0,0:19:57.47,0:20:04.44,main,,0000,0000,0000,,Mi Google ilin kaj provas la demonstraĵojn kaj antaŭ ol mi scias ĝin mi nur devas aĉeti ilin!
Dialogue: 0,0:20:04.80,0:20:08.94,main,,0000,0000,0000,,Kiom ajn fojoj mi provas halti, ĉi tiu beleco nur frenezigas min denove!
Dialogue: 0,0:20:09.44,0:20:15.61,main,,0000,0000,0000,,Ĉiu novaĵejo daŭre anoncas novajn informojn ĉiutage kaj igas min deziri aĉeti ilin.
Dialogue: 0,0:20:15.61,0:20:18.45,main,,0000,0000,0000,,Ĉio estas kulpo de KarzuSP kaj AkibaBlog!
Dialogue: 0,0:20:19.74,0:20:22.73,main,,0000,0000,0000,,Mi ne vere komprenas ĝin, sed vi povus simple ĉesi legi ilin.
Dialogue: 0,0:20:22.73,0:20:25.62,main,,0000,0000,0000,,Mi ne havus problemojn, se mi povus.
Dialogue: 0,0:20:26.56,0:20:28.96,main,,0000,0000,0000,,He, kion vi opinias, ke mi faru?
Dialogue: 0,0:20:29.32,0:20:31.20,main,,0000,0000,0000,,Kion vi devus fari?
Dialogue: 0,0:20:32.74,0:20:35.71,main,,0000,0000,0000,,Eble mi devus diri al panjo kaj paĉjo—
Dialogue: 0,0:20:35.71,0:20:36.50,main,,0000,0000,0000,,Ne faru tion!
Dialogue: 0,0:20:45.57,0:20:48.73,main,,0000,0000,0000,,Vi ne maltrankviliĝus, se vi povus.
Dialogue: 0,0:20:48.73,0:20:52.12,main,,0000,0000,0000,,Estos grandaj problemoj se paĉjo iam ekscios.
Dialogue: 0,0:20:52.60,0:20:55.06,main,,0000,0000,0000,,Mi eĉ ne volas pensi pri kio okazus.
Dialogue: 0,0:20:57.32,0:20:58.36,main,,0000,0000,0000,,mi vidas.
Dialogue: 0,0:21:00.24,0:21:02.60,main,,0000,0000,0000,,Mi komprenas ĝin.Mi helpos vin.
Dialogue: 0,0:21:02.60,0:21:04.99,main,,0000,0000,0000,,Mi zorgos, ke neniu ekscios pri via ŝatokupo.
Dialogue: 0,0:21:04.99,0:21:07.15,main,,0000,0000,0000,,Mi tamen ne scias, kion mi povas fari.
Dialogue: 0,0:21:07.15,0:21:08.02,main,,0000,0000,0000,,Ĉu vi faros?
Dialogue: 0,0:21:08.02,0:21:08.75,main,,0000,0000,0000,,Certe.
Dialogue: 0,0:21:08.75,0:21:11.02,main,,0000,0000,0000,,Se vi bezonas ion, simple demandu.
Dialogue: 0,0:21:11.02,0:21:13.34,main,,0000,0000,0000,,Ĉio ajn, kion mi povas fari, ĉiuokaze.
Dialogue: 0,0:21:13.73,0:21:15.38,main,,0000,0000,0000,,R-Ĉu vere?
Dialogue: 0,0:21:15.38,0:21:17.34,main,,0000,0000,0000,,Tiam mi supozas, ke mi faros...
Dialogue: 0,0:21:19.66,0:21:21.83,main,,0000,0000,0000,,Eble estus vera helpo se vi farus.
Dialogue: 0,0:21:25.17,0:21:27.01,main,,0000,0000,0000,,Mi tamen volas nur konfirmi unu aferon...
Dialogue: 0,0:21:27.01,0:21:31.10,main,,0000,0000,0000,,Vi ludas ĉi tiujn fratinetojn eroge ĉar vi amas fratinetojn, ĉu ne?
Dialogue: 0,0:21:31.10,0:21:33.12,main,,0000,0000,0000,,Ĉu?Mi diris tion, ĉu ne?
Dialogue: 0,0:21:34.52,0:21:36.10,main,,0000,0000,0000,,Ĉu vi ne havas kaŝpensojn?
Dialogue: 0,0:21:40.98,0:21:42.15,main,,0000,0000,0000,,Malpura!
Dialogue: 0,0:21:42.15,0:21:43.81,main,,0000,0000,0000,,Neniel mi farus!
Dialogue: 0,0:21:43.81,0:21:45.78,main,,0000,0000,0000,,Foriru de mi!
Dialogue: 0,0:21:45.78,0:21:47.43,main,,0000,0000,0000,,La plej malpura de ĉi tiu jaro!
Dialogue: 0,0:21:47.43,0:21:51.57,main,,0000,0000,0000,,Rigardu ĉi tien... en viaj ludoj, la pli juna fratino amas sian fraton, ĉu ne?
Dialogue: 0,0:21:51.57,0:21:52.42,main,,0000,0000,0000,,Ĉu vi estas stulta?
Dialogue: 0,0:21:52.42,0:21:54.95,main,,0000,0000,0000,,Ne miksu 2D kaj 3D!
Dialogue: 0,0:21:54.95,0:21:57.67,main,,0000,0000,0000,,Neniel iu fratino amus sian fraton en la reala vivo!
Dialogue: 0,0:21:59.76,0:22:02.25,main,,0000,0000,0000,,Tio pli similas al ŝi.
Dialogue: 0,0:22:02.25,0:22:05.22,main,,0000,0000,0000,,Ni finis ĉi tie, do eliru nun.
Dialogue: 0,0:22:05.22,0:22:06.31,main,,0000,0000,0000,,Jes, jes.
Dialogue: 0,0:22:15.60,0:22:16.36,main,,0000,0000,0000,,Mi supozas, ke mi dormos.
Dialogue: 0,0:22:22.11,0:22:23.68,main,,0000,0000,0000,,Tute ne bela.
Dialogue: 0,0:22:27.82,0:22:28.75,main,,0000,0000,0000,,Kio!
Dialogue: 0,0:22:29.13,0:22:32.37,main,,0000,0000,0000,,Pli da vivkonsilado.
Dialogue: 0,0:22:40.76,0:22:42.11,Screen-Sign,,0000,0000,0000,,{\be1\an4\pos(284,544.5)}Kyousuke
Dialogue: 0,0:22:40.80,0:22:40.84,Screen-Sign,,0000,0000,0000,,{\be1\an4\pos(250,634.5)}Ve!..Sh-Shiori......?
Dialogue: 0,0:22:42.22,0:22:42.26,Screen-Sign,,0000,0000,0000,,{\be1\an4\pos(250,604.5)}Shiori dormas apud mi.mi...
Dialogue: 0,0:22:44.18,0:22:48.17,Screen-Sign,,0000,0000,0000,,{\be1\an4\fad(150,0)\pos(324,130.5)}Brakumu ŝin milde kaj proksime
Dialogue: 0,0:22:44.18,0:22:48.17,Screen-Sign,,0000,0000,0000,,{\be1\an4\fad(150,0)\pos(324,225)}Elglitu el la lito sen veki ŝin
Dialogue: 0,0:22:44.18,0:22:48.17,Screen-Sign,,0000,0000,0000,,{\be1\an4\fad(150,0)\pos(324,318)}Fiŝu tion, forpelu ŝin el mia lito!
Dialogue: 0,0:22:48.85,0:22:50.76,Screen-Sign,,0000,0000,0000,,{\be1\an4\pos(284,544.5)}Kyousuke
Dialogue: 0,0:22:48.89,0:22:48.93,Screen-Sign,,0000,0000,0000,,{\pos(250,634.5)\be1\an4}Kion diable vi faras?!
Dialogue: 0,0:22:51.22,0:22:53.02,main,,0000,0000,0000,,Kion diable vi faras?!
Dialogue: 0,0:22:53.63,0:22:55.70,main,,0000,0000,0000,,Same al vi!Kion vi igas min fari?!
Dialogue: 0,0:22:55.70,0:22:56.79,main,,0000,0000,0000,,Vi estas nekredebla!
Dialogue: 0,0:22:56.79,0:22:59.53,main,,0000,0000,0000,,Kiel vi povas simple piedbati vian belan fratinon el via lito tiel?!
Dialogue: 0,0:22:59.77,0:23:01.36,main,,0000,0000,0000,,Ĉu ŝi serioze diras tion al mi,
Dialogue: 0,0:23:01.36,0:23:03.68,main,,0000,0000,0000,,post vangofrapo min veka meze de la nokto?!
Dialogue: 0,0:23:03.68,0:23:04.70,main,,0000,0000,0000,,Mi ne eraras ĉi tie!
Dialogue: 0,0:23:04.70,0:23:06.53,main,,0000,0000,0000,,Ĉi tio certe estas ŝia kulpo!
Dialogue: 0,0:23:06.81,0:23:13.05,main,,0000,0000,0000,,Kie en ĉi tiu mondo estas frato, kiu ludus ludon pri amo de fratineto kun sia fratineto?!
Dialogue: 0,0:23:13.61,0:23:16.54,main,,0000,0000,0000,,Mi-mi bedaŭras!Mi bedaŭras Onii-chan!
Dialogue: 0,0:23:16.78,0:23:19.91,main,,0000,0000,0000,,Vidu?Ĉu vi ne kompatas Shiori-chan?
Dialogue: 0,0:23:19.91,0:23:21.38,main,,0000,0000,0000,,Kion vi devas diri por vi mem?
Dialogue: 0,0:23:21.38,0:23:23.55,main,,0000,0000,0000,,Fratinetoj devus trakti siajn fratojn kun pli da respekto—
Dialogue: 0,0:23:23.55,0:23:24.95,main,,0000,0000,0000,,Ĉu?Kio estis tio?
Dialogue: 0,0:23:24.95,0:23:26.55,main,,0000,0000,0000,,Nenio.
Dialogue: 0,0:23:26.82,0:23:29.19,main,,0000,0000,0000,,Nun rapidu kaj daŭrigu!
Dialogue: 0,0:23:29.19,0:23:34.28,main,,0000,0000,0000,,Kiam mi diris, ke mi helpos vin, mi ne aludis al ĉi tio...
Dialogue: 0,0:23:34.28,0:23:35.03,main,,0000,0000,0000,,Ĉu?
Dialogue: 0,0:23:35.03,0:23:37.81,main,,0000,0000,0000,,Vi diris demandi vin, ĉu estas io, pri kio mi bezonas helpon!
Dialogue: 0,0:23:37.81,0:23:40.46,main,,0000,0000,0000,,Mi parolis pri sekreto de paĉjo!
Dialogue: 0,0:23:40.46,0:23:43.87,main,,0000,0000,0000,,Kial vi bezonas min ludi tra eroge kun vi?
Dialogue: 0,0:23:43.87,0:23:46.34,main,,0000,0000,0000,,Y-Vi nur bezonas!
Dialogue: 0,0:23:46.34,0:23:49.85,main,,0000,0000,0000,,Mi volas, ke iu donu al mi objektivan vidpunkton de ĉi tiu ludo!
Dialogue: 0,0:23:49.85,0:23:51.58,main,,0000,0000,0000,,Mi volas realan opinion.
Dialogue: 0,0:23:51.58,0:23:54.01,main,,0000,0000,0000,,Kiel mi povas esti objektiva pri tio?!
Dialogue: 0,0:23:54.56,0:23:56.22,main,,0000,0000,0000,,Venu, rigardu ĝin el mia perspektivo.
Dialogue: 0,0:23:56.22,0:24:00.74,main,,0000,0000,0000,,Antaŭ duona tago mi eĉ ne sciis, ke tia ludo ekzistas!
Dialogue: 0,0:24:00.74,0:24:04.12,main,,0000,0000,0000,,Ĉu ĵeti min en tian situacion ne estas iom multe?
Dialogue: 0,0:24:04.12,0:24:05.81,main,,0000,0000,0000,,Do vi ja mokas min.
Dialogue: 0,0:24:05.81,0:24:07.94,main,,0000,0000,0000,,Vi ĉiuj parolas finfine.
Dialogue: 0,0:24:07.94,0:24:09.97,main,,0000,0000,0000,,Vi estas antaŭjuĝema kontraŭ ĉi tiu ŝatokupo!
Dialogue: 0,0:24:10.29,0:24:11.74,main,,0000,0000,0000,,Ne estas tio!
Dialogue: 0,0:24:11.74,0:24:13.53,main,,0000,0000,0000,,Ĉi tio estas nur mallerta!
Dialogue: 0,0:24:13.53,0:24:16.73,main,,0000,0000,0000,,Estas kiel sidi kune en la salono spekti dramon kaj ĝi subite venas al kisa sceno!
Dialogue: 0,0:24:16.73,0:24:17.72,main,,0000,0000,0000,,Tiel estas!
Dialogue: 0,0:24:18.02,0:24:20.96,main,,0000,0000,0000,,Kio?Vi ne havas sencon.
Dialogue: 0,0:24:20.96,0:24:22.94,main,,0000,0000,0000,,Ĉi tio estas ludo R-18, ĉu ne?
Dialogue: 0,0:24:23.32,0:24:25.94,main,,0000,0000,0000,,"Tiaj" specoj de scenoj okazos, ĉu ne?
Dialogue: 0,0:24:26.36,0:24:31.80,main,,0000,0000,0000,,Ĉu vi vere konsentas spekti scenon kie frato kaj fratino faras tian aferon kun mi?
Dialogue: 0,0:24:32.33,0:24:34.39,main,,0000,0000,0000,,Malpura!!
Dialogue: 0,0:24:34.39,0:24:34.97,main,,0000,0000,0000,,Idioto!
Dialogue: 0,0:24:34.97,0:24:35.75,main,,0000,0000,0000,,Perversulo!
Dialogue: 0,0:24:36.42,0:24:38.25,main,,0000,0000,0000,,Kial vi efektive pensas pri tia afero?
Dialogue: 0,0:24:38.67,0:24:41.29,main,,0000,0000,0000,,Estus pli problemo se mi ne estus!!
Dialogue: 0,0:24:41.29,0:24:42.32,main,,0000,0000,0000,,Bone.
Dialogue: 0,0:24:44.19,0:24:47.30,main,,0000,0000,0000,,Mi elprenos la ĉiaĝan version nur por vi tiam.
Dialogue: 0,0:24:47.30,0:24:49.11,main,,0000,0000,0000,,Vi devus esti elpreninta tion de la komenco!
Dialogue: 0,0:24:49.11,0:24:51.26,main,,0000,0000,0000,,Kaj vi vere ne komprenas ĝin!
Dialogue: 0,0:24:51.66,0:24:55.77,main,,0000,0000,0000,,Vi povas nur plene aprezi la rakonton se vi ludas la originalan eldonon, tamen.
Dialogue: 0,0:24:56.23,0:25:00.27,main,,0000,0000,0000,,Se vi volas paroli pri tio, demandu viajn amikojn.
Dialogue: 0,0:25:00.27,0:25:02.48,main,,0000,0000,0000,,Ĉesu babili kaj prenu ĝin.
Dialogue: 0,0:25:05.91,0:25:08.41,main,,0000,0000,0000,,Jam estas sufiĉe malfrue, vi scias...
Dialogue: 0,0:25:08.41,0:25:11.09,main,,0000,0000,0000,,Kaj vi pruntedonos al mi vian tekkomputilon?
Dialogue: 0,0:25:11.09,0:25:15.08,main,,0000,0000,0000,,Poste mi ludos la version R-18 kiam mi havos iom da libera tempo.
Dialogue: 0,0:25:16.84,0:25:18.88,main,,0000,0000,0000,,Nu, se vi insistas...
Dialogue: 0,0:25:21.52,0:25:23.00,main,,0000,0000,0000,,Jen via hejmtasko do.
Dialogue: 0,0:25:23.00,0:25:25.34,main,,0000,0000,0000,,Klarigi ĉi tion antaŭ la venonta semajno.
Dialogue: 0,0:25:26.32,0:25:27.58,main,,0000,0000,0000,,Jes, jes.
Dialogue: 0,0:25:30.14,0:25:31.00,Screen-Sign,,0000,0000,0000,,{\fad(150,0)\be1\pos(652,237)}Ĉu eliri la ludon?
Dialogue: 0,0:25:31.48,0:25:32.87,main,,0000,0000,0000,,Onii-chan!
Dialogue: 0,0:25:32.87,0:25:34.31,main,,0000,0000,0000,,Ni ludu denove!
Dialogue: 0,0:25:34.31,0:25:35.86,main,,0000,0000,0000,,Ĝis revido!
Dialogue: 0,0:25:51.23,0:25:54.77,ed-rom,,0000,0000,0000,,Estas abomena!Terura!Ne staru tiel apud mi.
Dialogue: 0,0:25:51.23,0:25:54.77,ed-eng,,0000,0000,0000,,Malpura!Malpura!Ne staru apud mi publike!
Dialogue: 0,0:25:54.77,0:25:58.07,ed-rom,,0000,0000,0000,,Ĝi vere doloras!Ĉar ĉiuj rigardas min!Vi stulta frato!
Dialogue: 0,0:25:54.77,0:25:58.07,ed-eng,,0000,0000,0000,,Vi estas la plej malbona!Ne rigardu min tiel!Stulta frato!
Dialogue: 0,0:25:58.07,0:26:01.40,ed-rom,,0000,0000,0000,,Bonvolu doni al mi pli junan fratinon, kiu estas bonega loli, longa, moe, longa, aminda, kaj havas bonegan statuson.
Dialogue: 0,0:25:58.07,0:26:01.40,ed-eng,,0000,0000,0000,,Super loli - Super moe - Super amo - Super bela, donu al mi fratineton tiel!
Dialogue: 0,0:26:01.40,0:26:03.06,ed-rom,,0000,0000,0000,,Malgranda kaj brila
Dialogue: 0,0:26:01.40,0:26:03.06,ed-eng,,0000,0000,0000,,Malgranda kaj brila
Dialogue: 0,0:26:03.06,0:26:04.91,ed-rom,,0000,0000,0000,,Mia sola akva anĝelo
Dialogue: 0,0:26:03.06,0:26:04.91,ed-eng,,0000,0000,0000,,dolĉa anĝelo por mi sola.
Dialogue: 0,0:26:09.51,0:26:11.62,ed-rom,,0000,0000,0000,,Donu al mi belan fratineton...
Dialogue: 0,0:26:09.51,0:26:11.62,ed-eng,,0000,0000,0000,,Donu al mi belan fratineton...
Dialogue: 0,0:26:11.62,0:26:14.86,ed-rom,,0000,0000,0000,,Mi ne povas dormi sola, ĉu mi do povas dormi kun vi?
Dialogue: 0,0:26:11.62,0:26:14.86,ed-eng,,0000,0000,0000,,Mi ne povas dormi sola, ĉu mi povas dormi kun vi?
Dialogue: 0,0:26:14.86,0:26:17.76,ed-rom,,0000,0000,0000,,...Ho mia dio, mi estas tiel feliĉa, ĝi estas tiel freneza!Tio estas freneza!
Dialogue: 0,0:26:14.86,0:26:17.76,ed-eng,,0000,0000,0000,,... nur ŝercas.Ah!Mi estas vere feliĉa.Estas nur terure!Terura!
Dialogue: 0,0:26:17.76,0:26:21.48,ed-rom,,0000,0000,0000,,Ĉu?Nu, ne estas aparta kialo, kial mi pensas pri amo.
Dialogue: 0,0:26:17.76,0:26:21.48,ed-eng,,0000,0000,0000,,Kio?Mi-Ne estas kvazaŭ mi pensas pri amo aŭ io ajn!
Dialogue: 0,0:26:21.48,0:26:22.94,ed-rom,,0000,0000,0000,,Ĉu ne estas agrable havi sonĝon?
Dialogue: 0,0:26:21.48,0:26:22.94,ed-eng,,0000,0000,0000,,Ne estas bone deziri ĝin
Dialogue: 0,0:26:22.94,0:26:24.39,ed-rom,,0000,0000,0000,,fantazia rango problemo
Dialogue: 0,0:26:22.94,0:26:24.39,ed-eng,,0000,0000,0000,,sed ne estas problemo kiam temas nur pri fantazio.
Dialogue: 0,0:26:24.39,0:26:31.02,ed-rom,,0000,0000,0000,,La esenco de malgranda stimulo por via ĉiutaga rut
Dialogue: 0,0:26:24.39,0:26:31.02,ed-eng,,0000,0000,0000,,En via ĉiutaga bezono, ĉu vi bezonas
Dialogue: 0,0:26:31.02,0:26:36.11,ed-rom,,0000,0000,0000,,Vi bezonas ĝin, ĉu ne?
Dialogue: 0,0:26:31.02,0:26:36.11,ed-eng,,0000,0000,0000,,iom da instigo?
Dialogue: 0,0:26:37.69,0:26:40.84,ed-rom,,0000,0000,0000,,5-a ilaro mi komprenas.
Dialogue: 0,0:26:37.69,0:26:40.84,ed-eng,,0000,0000,0000,,Iun tagon vi devus kompreni
Dialogue: 0,0:26:40.84,0:26:44.29,ed-rom,,0000,0000,0000,,Io misas ĉe iu grava por mi.
Dialogue: 0,0:26:40.84,0:26:44.29,ed-eng,,0000,0000,0000,,kio estas la plej grava afero.
Dialogue: 0,0:26:44.29,0:26:49.08,ed-rom,,0000,0000,0000,,Mi bezonas fratineton!
Dialogue: 0,0:26:44.29,0:26:49.08,ed-eng,,0000,0000,0000,,Mi bezonas fratineton!
Dialogue: 0,0:26:49.08,0:26:50.64,ed-rom,,0000,0000,0000,,absolute!
Dialogue: 0,0:26:49.08,0:26:50.64,ed-eng,,0000,0000,0000,,Mi vere faras!
Dialogue: 0,0:27:07.61,0:27:12.60,title,,0000,0000,0000,,{\shad0\fs60\fnAngeleobardo\c&H4ED67F&\bord0.15\be1\frz4.249\pos(362,150)}Ne estas maniero, ke mi irus al 0000IRL Renkontiĝo kun mia fratino
Dialogue: 0,0:27:08.48,0:27:09.30,main,,0000,0000,0000,,Venontfoje:
Dialogue: 0,0:27:09.30,0:27:12.60,main,,0000,0000,0000,,Estas Nenie Mi irus al IRL-Renkontiĝo kun Mia Fratino
